APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# stack uses LOG_STACK channels (default: daily_env → file per day: storage/logs/YYYY-MM-DD-{APP_ENV}.log)
LOG_CHANNEL=stack
LOG_STACK=daily_env
LOG_LEVEL=debug
# When false, skips INFO logs for each completed controller action (controller.action.success).
LOG_CONTROLLER_ACTIONS=true

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# When true, logs each authenticated POST/PUT/PATCH/DELETE with sanitized request + status (in addition to model audits).
AUDIT_LOG_HTTP=false
# When true, report HTML views (sales / periodic) also write audit_logs rows; exports/prints always do.
AUDIT_LOG_REPORT_VIEWS=false

# Nightly platform backups: php artisan backup:scheduled-platform (scheduled in app/Console/Kernel.php at 00:00).
# Requires cron: * * * * * cd /path-to-app && php artisan schedule:run >> /dev/null 2>&1
BACKUP_SCHEDULE_ENABLED=true
BACKUP_SCHEDULE_RETENTION_DAYS=30
# Full path to mysqldump if not on PHP's PATH (common on macOS: /opt/homebrew/bin/mysqldump or mysql-client keg: /opt/homebrew/opt/mysql-client/bin/mysqldump)
# BACKUP_MYSQLDUMP=
# PHP CLI used to run backups in the background (avoid php-fpm). Example: /opt/homebrew/bin/php
# PHP_CLI_PATH=php

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Laravel Dusk browser tests: copy to .env.dusk.local (or duplicate .env) before `php artisan dusk`.
# Set APP_URL to the running dev server, including port (e.g. http://127.0.0.1:8000) — not http://localhost alone.
# Run `php artisan serve` and ChromeDriver: `bash scripts/dusk-chromedriver.sh`.
# DUSK_LOGIN_EMAIL=admin@gmail.com
# DUSK_LOGIN_PASSWORD=secret
