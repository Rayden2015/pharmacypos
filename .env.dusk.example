# Laravel Dusk: copy your working .env to `.env.dusk.local` (this file is only a checklist).
#
#   cp .env .env.dusk.local
#
# Then confirm for browser runs (port required if you use `php artisan serve`):
#   APP_URL=http://127.0.0.1:8000
#   APP_KEY=   (must be set — same as local is fine)
#   DB_*       (database must include AdminSeeder user)
#
# Optional overrides (defaults match AdminSeeder):
# DUSK_LOGIN_EMAIL=admin@gmail.com
# DUSK_LOGIN_PASSWORD=secret
#
# Before `php artisan dusk`:
#   php artisan serve
#   bash scripts/dusk-chromedriver.sh
#
# Keep SENTRY_LARAVEL_DSN empty in `.env.dusk.local` unless you intend to send Dusk traffic to Sentry.

